model Setting {
  /// NOTE: IDs are currently app-assigned to match legacy Mongo ObjectId imports.
  /// If you create new records without supplying `id`, add `@default(cuid())` (or uuid()).
  id String @id

  aboutUs            String?
  privacyPolicy      String?
  termsAndConditions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
