# Source control
.git
.gitignore

# Dependencies (installed inside container)
node_modules

# Compiled output (built inside container)
dist

# Environment files (injected at runtime)
.env
.env.*

# Docker files (no need to copy into image)
Dockerfile
docker-compose*

# Editor / OS
.vscode
.DS_Store
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build info
*.tsbuildinfo

# Test coverage
coverage

# CI / misc
.github
